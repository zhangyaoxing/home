#!/usr/bin/env python3
"""Watchdog: restarts the app when git changes are detected."""

import os
import signal
import subprocess
import sys
import time

CHECK_INTERVAL = 3
RETRY_DELAY = 30


def has_changes():
    if (
        subprocess.run(["git", "diff", "--quiet"]).returncode != 0
        or subprocess.run(["git", "diff", "--cached", "--quiet"]).returncode != 0
    ):
        return True
    return _remote_has_incoming()


def _remote_has_incoming():
    subprocess.run(["git", "fetch", "--quiet"])
    result = subprocess.run(
        ["git", "rev-list", "--count", "HEAD..@{u}"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return False
    return int(result.stdout.strip()) > 0


def start_app():
    proc = subprocess.Popen(
        [sys.executable, "-m", "home_control_panel.app"],
        env={**os.environ, "PYTHONPATH": "src"},
    )
    try:
        os.tcsetpgrp(sys.stdin.fileno(), proc.pid)
    except OSError:
        pass
    return proc


def reclaim_terminal():
    try:
        os.tcsetpgrp(sys.stdin.fileno(), os.getpid())
    except OSError:
        pass


def timestamp():
    return time.strftime("%H:%M:%S")


def kill_app(proc):
    proc.terminate()
    try:
        proc.wait(timeout=5)
    except subprocess.TimeoutExpired:
        proc.kill()
        proc.wait()


def run_loop():
    signal.signal(signal.SIGTTOU, signal.SIG_IGN)

    proc = start_app()
    print(f"{timestamp()} App started (PID: {proc.pid}).")

    while True:
        time.sleep(CHECK_INTERVAL)

        exit_code = proc.poll()
        if exit_code is not None:
            reclaim_terminal()
            if exit_code == 0:
                print(f"{timestamp()} App exited normally. Stopping.")
                return
            print(f"{timestamp()} App crashed (exit {exit_code}).")

            if not has_changes():
                print(f"{timestamp()} Waiting for changes...")
                while not has_changes():
                    time.sleep(CHECK_INTERVAL)

            proc = _restart()
            continue

        if has_changes():
            print(f"{timestamp()} Changes detected, restarting...")
            kill_app(proc)
            reclaim_terminal()
            proc = _restart()


def _restart():
    print(f"{timestamp()} Restarting...")
    while True:
        proc = start_app()
        time.sleep(2)
        if proc.poll() is None:
            print(f"{timestamp()} App started (PID: {proc.pid}).")
            return proc
        reclaim_terminal()
        print(f"{timestamp()} Start failed, retrying in {RETRY_DELAY}s...")
        time.sleep(RETRY_DELAY)


if __name__ == "__main__":
    run_loop()
