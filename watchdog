#!/usr/bin/env python3
"""Watchdog: restarts the app when git changes are detected."""

import json
import errno
import os
import signal
import shutil
import socket
import subprocess
import sys
import time

CHECK_INTERVAL = 3
RETRY_DELAY = 30
SERVE_PORT = 8093
LOG_DIR = "logs"
STARTED_PROCESSES = []

with open("src/home_control_panel/config.json") as f:
    _config = json.load(f)
SERVE_URL = _config["serveHost"]
if not SERVE_URL.startswith(("http://", "https://")):
    SERVE_URL = f"https://{SERVE_URL}"


def has_changes():
    return _remote_has_incoming()


def _remote_has_incoming():
    subprocess.run(["git", "fetch", "--quiet"])
    result = subprocess.run(
        ["git", "rev-list", "--count", "HEAD..@{u}"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return False
    return int(result.stdout.strip()) > 0


def start_serve():
    """Start textual serve in the background and return the process handle."""
    textual = shutil.which("textual")
    if textual is None:
        raise RuntimeError(
            "Could not find the 'textual' command. Install dev dependencies with "
            "'python -m pip install -e \".[dev]\"'."
        )
    if port_is_in_use("0.0.0.0", SERVE_PORT):
        raise RuntimeError(
            f"Port {SERVE_PORT} is already in use. Stop the existing textual serve "
            "process before starting watchdog."
        )
    log = open_log("textual-serve.log")
    return track_process(
        subprocess.Popen(
            [
                textual,
                "serve",
                "-h",
                "0.0.0.0",
                "--port",
                str(SERVE_PORT),
                "--url",
                SERVE_URL,
                "src/home_control_panel/app.py",
            ],
            env={**os.environ, "PYTHONPATH": "src"},
            stdout=log,
            stderr=subprocess.STDOUT,
            start_new_session=True,
        ),
        "Serve",
        process_group=True,
    )


def start_api_service():
    """Start the API service in the background and return the process handle."""
    log = open_log("api-service.log")
    return track_process(
        subprocess.Popen(
            [sys.executable, "-m", "home_control_panel.api_service"],
            env={**os.environ, "PYTHONPATH": "src"},
            stdout=log,
            stderr=subprocess.STDOUT,
            start_new_session=True,
        ),
        "API service",
        process_group=True,
    )


def start_app():
    """Start the local Textual app attached to the current terminal."""
    return track_process(
        subprocess.Popen(
            [sys.executable, "-m", "home_control_panel.app"],
            env={**os.environ, "PYTHONPATH": "src"},
        ),
        "App",
        process_group=False,
    )


def track_process(process, label, process_group):
    STARTED_PROCESSES.append((process, label, process_group))
    return process


def open_log(filename):
    os.makedirs(LOG_DIR, exist_ok=True)
    return open(os.path.join(LOG_DIR, filename), "a", buffering=1)


def port_is_in_use(host, port):
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        try:
            sock.bind((host, port))
        except OSError as exc:
            if exc.errno == errno.EADDRINUSE:
                return True
            raise
        return False


def pull_changes():
    """Pull remote changes. Returns (success, pyproject_changed)."""
    before = _git_rev_parse("HEAD")
    result = subprocess.run(
        ["git", "pull", "--ff-only", "--quiet"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        stderr = result.stderr.strip()
        print(f"{timestamp()} Pull failed: {stderr}")
        return False, False
    after = _git_rev_parse("HEAD")
    pyproject_changed = _file_changed_between(before, after, "pyproject.toml")
    return True, pyproject_changed


def _git_rev_parse(revision):
    result = subprocess.run(
        ["git", "rev-parse", revision],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return None
    return result.stdout.strip()


def _file_changed_between(before, after, path):
    if before is None or after is None or before == after:
        return False
    result = subprocess.run(
        ["git", "diff", "--name-only", before, after, "--", path],
        capture_output=True,
        text=True,
    )
    return result.returncode == 0 and bool(result.stdout.strip())


def install_dependencies():
    """Install dependencies from pyproject.toml. Returns True on success."""
    result = subprocess.run(
        [sys.executable, "-m", "pip", "install", "-e", "."],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        stderr = result.stderr.strip()
        print(f"{timestamp()} Dependency install failed: {stderr}")
        return False
    return True


def process_exited(process):
    """Check whether the given process has exited. Returns exit_code or None."""
    return process.poll()


def kill_process(process, label, process_group=True):
    if process.poll() is not None:
        return
    try:
        if process_group:
            os.killpg(process.pid, signal.SIGTERM)
        else:
            process.terminate()
    except ProcessLookupError:
        return
    for _ in range(50):  # 5 seconds
        if process.poll() is not None:
            return
        time.sleep(0.1)
    try:
        if process_group:
            os.killpg(process.pid, signal.SIGKILL)
        else:
            process.kill()
        process.wait()
    except ProcessLookupError:
        pass


def kill_all(serve_process, api_process, app_process):
    if app_process is not None:
        kill_process(app_process, "App", process_group=False)
    if api_process is not None:
        kill_process(api_process, "API service")
    if serve_process is not None:
        kill_process(serve_process, "Serve")


def cleanup_started_processes():
    for process, label, process_group in reversed(STARTED_PROCESSES):
        kill_process(process, label, process_group=process_group)


def exit_from_signal(signum, _frame):
    print(f"{timestamp()} Watchdog received signal {signum}. Stopping.")
    raise SystemExit(128 + signum)


def timestamp():
    return time.strftime("%H:%M:%S")


def update_dependencies_if_needed(pyproject_changed):
    if not pyproject_changed:
        return True
    return install_dependencies()


def run_loop():
    serve_process = start_serve()
    api_process = start_api_service()
    app_process = start_app()
    print(
        f"{timestamp()} Serve started (PID: {serve_process.pid}), "
        f"API service (PID: {api_process.pid}), "
        f"App (PID: {app_process.pid})."
    )

    while True:
        time.sleep(CHECK_INTERVAL)

        exit_code = process_exited(serve_process)
        if exit_code is not None:
            print(f"{timestamp()} Serve exited (exit {exit_code}), restarting...")
            kill_all(serve_process, api_process, app_process)
            serve_process, api_process, app_process = _restart()
            continue

        api_exit = process_exited(api_process)
        if api_exit is not None:
            print(f"{timestamp()} API service crashed (exit {api_exit}), restarting...")
            api_process = start_api_service()
            print(f"{timestamp()} API service restarted (PID: {api_process.pid}).")

        app_exit = process_exited(app_process)
        if app_exit is not None:
            if app_exit == 0:
                print(f"{timestamp()} App exited normally. Stopping watchdog.")
                kill_all(serve_process, api_process, app_process)
                return
            print(f"{timestamp()} App crashed (exit {app_exit}), restarting...")
            app_process = start_app()
            print(f"{timestamp()} App restarted (PID: {app_process.pid}).")

        if has_changes():
            print(f"{timestamp()} Changes detected, pulling...")
            pulled, pyproject_changed = pull_changes()
            if pulled:
                if update_dependencies_if_needed(pyproject_changed):
                    kill_all(serve_process, api_process, app_process)
                    serve_process, api_process, app_process = _restart()
                else:
                    print(f"{timestamp()} Skipping restart due to install failure.")


def _restart():
    print(f"{timestamp()} Restarting...")
    while True:
        serve_process = start_serve()
        api_process = start_api_service()
        app_process = start_app()
        time.sleep(2)
        serve_ok = process_exited(serve_process) is None
        api_ok = process_exited(api_process) is None
        app_ok = process_exited(app_process) is None
        if serve_ok and api_ok and app_ok:
            print(
                f"{timestamp()} Serve started (PID: {serve_process.pid}), "
                f"API service (PID: {api_process.pid}), "
                f"App (PID: {app_process.pid})."
            )
            return serve_process, api_process, app_process
        kill_all(serve_process, api_process, app_process)
        print(f"{timestamp()} Start failed, retrying in {RETRY_DELAY}s...")
        time.sleep(RETRY_DELAY)


if __name__ == "__main__":
    signal.signal(signal.SIGINT, exit_from_signal)
    signal.signal(signal.SIGTERM, exit_from_signal)
    try:
        run_loop()
    finally:
        cleanup_started_processes()
