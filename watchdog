#!/usr/bin/env python3
"""Watchdog: restarts the app when git changes are detected."""

import json
import os
import signal
import subprocess
import sys
import time

CHECK_INTERVAL = 3
RETRY_DELAY = 30

with open("src/home_control_panel/config.json") as f:
    _config = json.load(f)
SERVE_HOST = _config["serveHost"].removeprefix("https://").removeprefix("http://")


def has_changes():
    return _remote_has_incoming()


def _remote_has_incoming():
    subprocess.run(["git", "fetch", "--quiet"])
    result = subprocess.run(
        ["git", "rev-list", "--count", "HEAD..@{u}"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return False
    return int(result.stdout.strip()) > 0


def start_serve():
    """Fork and exec textual serve. Child inherits terminal control from parent."""
    pid = os.fork()
    if pid == 0:
        os.execvpe(
            sys.executable,
            [
                sys.executable,
                "-m", "textual",
                "serve",
                "-h", SERVE_HOST,
                "src/home_control_panel/app.py",
            ],
            {**os.environ, "PYTHONPATH": "src"},
        )
    return pid


def start_api_service():
    """Fork and exec the API service."""
    pid = os.fork()
    if pid == 0:
        os.execvpe(
            sys.executable,
            [sys.executable, "-m", "home_control_panel.api_service"],
            {**os.environ, "PYTHONPATH": "src"},
        )
    return pid


def pull_changes():
    """Pull remote changes. Returns (success, pyproject_changed)."""
    before = _git_rev_parse("HEAD")
    result = subprocess.run(
        ["git", "pull", "--ff-only", "--quiet"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        stderr = result.stderr.strip()
        print(f"{timestamp()} Pull failed: {stderr}")
        return False, False
    after = _git_rev_parse("HEAD")
    pyproject_changed = _file_changed_between(before, after, "pyproject.toml")
    return True, pyproject_changed


def _git_rev_parse(revision):
    result = subprocess.run(
        ["git", "rev-parse", revision],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return None
    return result.stdout.strip()


def _file_changed_between(before, after, path):
    if before is None or after is None or before == after:
        return False
    result = subprocess.run(
        ["git", "diff", "--name-only", before, after, "--", path],
        capture_output=True,
        text=True,
    )
    return result.returncode == 0 and bool(result.stdout.strip())


def install_dependencies():
    """Install dependencies from pyproject.toml. Returns True on success."""
    result = subprocess.run(
        [sys.executable, "-m", "pip", "install", "-e", "."],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        stderr = result.stderr.strip()
        print(f"{timestamp()} Dependency install failed: {stderr}")
        return False
    return True


def app_exited(pid):
    """Check whether the given child has exited. Returns exit_code or None."""
    try:
        wpid, status = os.waitpid(pid, os.WNOHANG)
    except ChildProcessError:
        return -1
    if wpid == 0:
        return None
    return os.waitstatus_to_exitcode(status)


def kill_process(pid, label):
    try:
        os.kill(pid, signal.SIGTERM)
    except ProcessLookupError:
        return
    for _ in range(50):  # 5 seconds
        if app_exited(pid) is not None:
            return
        time.sleep(0.1)
    try:
        os.kill(pid, signal.SIGKILL)
        os.waitpid(pid, 0)
    except (ProcessLookupError, ChildProcessError):
        pass


def kill_all(app_pid, api_pid):
    if api_pid is not None:
        kill_process(api_pid, "API service")
    if app_pid is not None:
        kill_process(app_pid, "App")


def timestamp():
    return time.strftime("%H:%M:%S")


def update_dependencies_if_needed(pyproject_changed):
    if not pyproject_changed:
        return True
    return install_dependencies()


def run_loop():
    app_pid = start_serve()
    api_pid = start_api_service()
    print(f"{timestamp()} Serve started (PID: {app_pid}), API service (PID: {api_pid}).")

    while True:
        time.sleep(CHECK_INTERVAL)

        exit_code = app_exited(app_pid)
        if exit_code is not None:
            if exit_code == 0:
                print(f"{timestamp()} Serve exited normally. Stopping.")
                kill_all(app_pid, api_pid)
                return
            print(f"{timestamp()} Serve crashed (exit {exit_code}).")

            if not has_changes():
                print(f"{timestamp()} Waiting for changes...")
                while not has_changes():
                    time.sleep(CHECK_INTERVAL)

            print(f"{timestamp()} Changes detected, pulling...")
            pulled, pyproject_changed = pull_changes()
            if pulled:
                if update_dependencies_if_needed(pyproject_changed):
                    kill_all(app_pid, api_pid)
                    app_pid, api_pid = _restart()
                else:
                    print(f"{timestamp()} Skipping restart due to install failure.")
            else:
                print(f"{timestamp()} Skipping restart due to pull failure.")
            continue

        api_exit = app_exited(api_pid)
        if api_exit is not None:
            print(f"{timestamp()} API service crashed (exit {api_exit}), restarting...")
            api_pid = start_api_service()
            print(f"{timestamp()} API service restarted (PID: {api_pid}).")

        if has_changes():
            print(f"{timestamp()} Changes detected, pulling...")
            pulled, pyproject_changed = pull_changes()
            if pulled:
                if update_dependencies_if_needed(pyproject_changed):
                    kill_all(app_pid, api_pid)
                    app_pid, api_pid = _restart()
                else:
                    print(f"{timestamp()} Skipping restart due to install failure.")


def _restart():
    print(f"{timestamp()} Restarting...")
    while True:
        app_pid = start_serve()
        api_pid = start_api_service()
        time.sleep(2)
        app_ok = app_exited(app_pid) is None
        api_ok = app_exited(api_pid) is None
        if app_ok and api_ok:
            print(f"{timestamp()} Serve started (PID: {app_pid}), API service (PID: {api_pid}).")
            return app_pid, api_pid
        print(f"{timestamp()} Start failed, retrying in {RETRY_DELAY}s...")
        time.sleep(RETRY_DELAY)


if __name__ == "__main__":
    run_loop()
