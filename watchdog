#!/usr/bin/env python3
"""Watchdog: restarts the app when git changes are detected."""

import os
import signal
import subprocess
import sys
import time

CHECK_INTERVAL = 3
RETRY_DELAY = 30


def has_changes():
    return _remote_has_incoming()


def _remote_has_incoming():
    subprocess.run(["git", "fetch", "--quiet"])
    result = subprocess.run(
        ["git", "rev-list", "--count", "HEAD..@{u}"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return False
    return int(result.stdout.strip()) > 0


def start_app():
    """Fork and exec the app. Child inherits terminal control from parent."""
    pid = os.fork()
    if pid == 0:
        os.execvpe(
            sys.executable,
            [sys.executable, "-m", "home_control_panel.app"],
            {**os.environ, "PYTHONPATH": "src"},
        )
    return pid


def app_exited(pid):
    """Check whether the given child has exited. Returns exit_code or None."""
    try:
        wpid, status = os.waitpid(pid, os.WNOHANG)
    except ChildProcessError:
        return -1
    if wpid == 0:
        return None
    return os.waitstatus_to_exitcode(status)


def kill_app(pid):
    os.kill(pid, signal.SIGTERM)
    for _ in range(50):  # 5 seconds
        if app_exited(pid) is not None:
            return
        time.sleep(0.1)
    os.kill(pid, signal.SIGKILL)
    os.waitpid(pid, 0)


def timestamp():
    return time.strftime("%H:%M:%S")


def run_loop():
    pid = start_app()
    print(f"{timestamp()} App started (PID: {pid}).")

    while True:
        time.sleep(CHECK_INTERVAL)

        exit_code = app_exited(pid)
        if exit_code is not None:
            if exit_code == 0:
                print(f"{timestamp()} App exited normally. Stopping.")
                return
            print(f"{timestamp()} App crashed (exit {exit_code}).")

            if not has_changes():
                print(f"{timestamp()} Waiting for changes...")
                while not has_changes():
                    time.sleep(CHECK_INTERVAL)

            pid = _restart()
            continue

        if has_changes():
            print(f"{timestamp()} Changes detected, restarting...")
            kill_app(pid)
            pid = _restart()


def _restart():
    print(f"{timestamp()} Restarting...")
    while True:
        pid = start_app()
        time.sleep(2)
        if app_exited(pid) is None:
            print(f"{timestamp()} App started (PID: {pid}).")
            return pid
        print(f"{timestamp()} Start failed, retrying in {RETRY_DELAY}s...")
        time.sleep(RETRY_DELAY)


if __name__ == "__main__":
    run_loop()
